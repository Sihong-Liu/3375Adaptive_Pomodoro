#define LED_BASE	       0xFF200000
#define HEX3_HEX0          0xFF200020 //for first 4 digits, showing seconds and minutes 
#define HEX5_HEX4          0xFF200030 //for last 2 digits, showing hours
#define SW_BASE            0xFF200040
#define LOAD               0xFFFEC600
#define COUNT              0xFFFEC604
#define CONTROL            0xFFFEC608
#define STATUS             0xFFFEC60C
#define BUTTONS            0xFF200060 
#define KEY_ACTIVE_LOW 1 // this revers the logic of buttons, now when pressed, it's 1.
volatile unsigned char second; //represents 1s place
volatile unsigned char ten_second; //represents 10s place
volatile unsigned char minute; //represents 1min place
volatile unsigned char ten_minute; //represents 10min place
volatile unsigned char hour; //represents 1hr place
volatile unsigned char ten_hour; //represents 10hr place
volatile unsigned int default_pomodoro_time = 40 * 60 * 100; //40 minutes in hundredths of seconds as default.
volatile unsigned int adapted_pomodoro_time; // default_pomodoro_time + adapted_delta_time.
volatile unsigned int remaining_time;  // this will be the time that is currently counting down, it = adapted_pomodoro_time when start button is pressed.
volatile unsigned int time_studied; // this is an accumulated amount for studied time.
volatile int adapted_delta_time = 0; // default_pomodoro_time 's modifier, positive is adding, negative is reducing. adapted_pomodoro_time is calculated by default_pomodoro_time + adapted_delta_time. 
volatile unsigned int time_skipped; //this equals to the remaining_time when the break button is pressed. it's for calculating the adapted_delta_time

//setting the control register globally
volatile unsigned int *control_ptr = (volatile unsigned int *) CONTROL;// this pointer will be used to start and stop the timer by writing to the control register
volatile unsigned int *load_ptr = (volatile unsigned int *) LOAD;// this pointer will be used to load the timer with the adapted_pomodoro_time when the timer is started
volatile unsigned int *count_ptr = (volatile unsigned int *) COUNT;//this register will be used to read the current value of the timer, it will be used to calculate the remaining time when the timer is stopped
volatile unsigned int *status_ptr = (volatile unsigned int *) STATUS;//flag tells us when timer has reached 0
volatile unsigned int *sw_ptr = (volatile unsigned int *) SW_BASE;
volatile unsigned int *btns_ptr = (volatile unsigned int *) BUTTONS;
volatile unsigned int *hex3_hex0_ptr = (volatile unsigned int *) HEX3_HEX0;//4 digits for seconds and minutes
volatile unsigned int *hex5_hex4_ptr = (volatile unsigned int *) HEX5_HEX4;//2 digits for hours
volatile unsigned int *leds_ptr = (volatile unsigned int *) LED_BASE;


//
typedef enum {
    ENDED, IDLE,RUNNING
}TimerState;
volatile TimerState state = ENDED;

void DisplayHex(unsigned int value)
    {
        //this code has to break elapse apart into minutes, seconds, and 10ths of seconds for display
        //Then, the code has to display the correct brokwn up divisions of elapse into the correct slots.
        //The value 1943.52s represents 32 minutes, 23 seconds, and 520ms. so, elapse = 194352
        //use that example to run calculations
        unsigned int s  = (value / 100) % 60; // 23 seconds
        unsigned int m  = (value / 6000) % 100; //32 minutes
        unsigned int h  = (value / 360000) % 100; //1 hour
        second           = s % 10; //3
        ten_second       = s / 10; //2
        minute           = m % 10; //2
        ten_minute       = m / 10; //3
        hour             = h; //1 hour
        ten_hour         = h / 10; //0 hour

        static const unsigned char seven_seg[10] = {
            0x3F, // 0
            0x06, // 1
            0x5B, // 2
            0x4F, // 3
            0x66, // 4
            0x6D, // 5
            0x7D, // 6
            0x07, // 7
            0x7F, // 8
            0x6F, // 9
        };

        unsigned int display_word1 = (seven_seg[ten_minute]       << 24) |
                            (seven_seg[minute]           << 16) |
                            (seven_seg[ten_second]     << 8)  |
                            (seven_seg[second]); //
        *hex3_hex0_ptr = display_word1;

        unsigned int display_word2 = (seven_seg[ten_hour]   <<8)|
                                (seven_seg[hour]);
        *hex5_hex4_ptr = display_word2;

}

int ReadBtns(void)// this function will read the keys and return a 4 bit value representing which keys are pressed. The value will be 0 if no keys are pressed, 1 if key0 is pressed, 2 if key1 is pressed, 4 if key2 is pressed, and 8 if key3 is pressed. If multiple keys are pressed, the value will be the sum of the values for each key. For example, if key0 and key2 are pressed, the value will be 5 (1 + 4).
    {
        int raw = *btns_ptr & 0xF;// read the raw value of the buttons, we only care about the first 4 bits
        return KEY_ACTIVE_LOW ? ((~raw) & 0xF) : raw;// if active low, we need to invert the raw value to get the correct button states
    }
    
int ReadSwitches(void) // this function will read the switches and return a 3 bit value representing which switches are on. The value will be 0 if no switches are on, 1 if switch1 is on, 2 if switch2 is on, and 4 if switch3 is on. If multiple switches are on, the value will be the sum of the values for each switch. For example, if switch1 and switch3 are on, the value will be 5 (1 + 4).
    {
        int switch_index = *sw_ptr & 0b111;
        return switch_index;
    }

    void SetModeLed(int switch_index)//set one LED on to indicate which mode is displayed.
{
    if (switch_index == 0) {
        *leds_ptr = 0x1;
    } else if (switch_index == 1) {
        *leds_ptr = 0x2;
    } else {
        *leds_ptr = 0x4;
    }
}

void DisplaySelectedTime(int switch_index)
    {

        if (switch_index == 0)
        {
            SetModeLed(switch_index); // clear the LEDs for switch 0
            DisplayHex(remaining_time);// if the switch is on, display the remaining time
        }
        else if (switch_index == 1)
        {
            SetModeLed(switch_index); // clear the LEDs for switch 1
            DisplayHex(adapted_pomodoro_time);// show total length of this porodoro session
        }
        else
        {
            SetModeLed(switch_index); // clear the LEDs for switch 2
            DisplayHex(time_studied);// show the net time studied in the session. Resets at end. 
        }
    }



void btn0_action(void)
    {
        // this function will be called when button 0 is pressed, it will start the timer
        // it will use adapted_pomodoro_time as the time to count down from and will set is_running to 1
        if (state==IDLE) // only start the timer if it's not already running
        {   
            *control_ptr |= 0b1;// start the timer in continuous mode
            time_studied = 0; // reset time_studied to 0 when the timer is started
            remaining_time = adapted_pomodoro_time; // set remaining_time to adapted_pomodoro_time when the timer is started
            
            state = RUNNING; // set the state to RUNNING
            DisplaySelectedTime(ReadSwitches());
        }
        else if (state == ENDED) // if the timer has ended, we can start a new session by pressing the start button again
        {
            *control_ptr |= 0b1;// start the timer in continuous mode
            time_studied = 0; // reset time_studied to 0 when the timer is started
            remaining_time = default_pomodoro_time; // set remaining_time to default_pomodoro_time when the timer is started
            adapted_pomodoro_time = default_pomodoro_time; // reset adapted_pomodoro_time to default_pomodoro_time when the timer is started
            state = RUNNING; // set the state to RUNNING
            DisplaySelectedTime(ReadSwitches());
        }
    }

void btn1_action(void){
        // this function will be called when button 1 is pressed, it will stop the timer
        // it is a indication of user want to take a break, 
        //so then the function calculate new adapted_delta_time based on the remaining time and the default porodoro time, 
        //then calculate new adapted_porodoro_time based on the adapted_delta_time and the default porodoro time
        if(state == RUNNING){
            *control_ptr &= ~1u; // stop the timer
            state = IDLE; // set the state to IDLE
            DisplaySelectedTime(ReadSwitches()); // update the display to show the selected time
             // calculate new adapted_delta_time based on the remaining time and the default porodoro time
            if (time_studied < adapted_pomodoro_time) {
                adapted_delta_time -= 2 * 60 * 100;   // minus 2 minutes if user takes a break before time up
            }
            adapted_pomodoro_time = default_pomodoro_time + adapted_delta_time; // calculate new adapted_porodoro_time based on the adapted_delta_time and the default porodoro time
        }
    }

    void btn3_action(){
        if(state == IDLE){
            // this function will be called when button 3 is pressed, it will reset the timer(need to press break first)
            // it will set is_running to 0 and clear adapted_delta_time and adapted_porodoro_time, and set remaining_time back to default_porodoro_time
            *control_ptr &= ~1u; // stop the timer
            DisplaySelectedTime(ReadSwitches()); // update the display to show the selected time
            state = ENDED; // set the state to ENDED
            adapted_delta_time = 0; // clear adapted_delta_time
            adapted_pomodoro_time = default_pomodoro_time; // reset adapted_porodoro_time to default_porodoro_time
            remaining_time = default_pomodoro_time; // set remaining_time back to default_porodoro_time
            time_studied = 0; // reset time_studied to 0
        }
    }

void main(void)
    {
        // initialize the display to show the default porodoro time
        adapted_delta_time = 0; // at the start, there is no adaptation, so adapted_delta_time is 0
        adapted_pomodoro_time = default_pomodoro_time + adapted_delta_time; // adapted_porodoro_time is just the default time at the start
        DisplaySelectedTime(ReadSwitches()); // update the display to show the selected time
        volatile int old_sw1 = 0;
        volatile int old_sw2 = 0;
        volatile int old_sw3 = 0;
        volatile int selected_sw = 0;
        *load_ptr=200000;//this should be 10ms
        *control_ptr = 0b11;
        *control_ptr &= ~1u;
        while (1)
        {
            int sw = ReadSwitches(); // read the switches
            int btns = ReadBtns(); // read the buttons
            if (sw & 0x1) {
                selected_sw = 0;
            } else if (sw & 0x2) {
                selected_sw = 1;
            } else if (sw & 0x4) {
                selected_sw = 3;
            }
            DisplaySelectedTime(selected_sw);
            if (switch1 != old_sw1)
            {
                selected_sw = 0;
            }
            if (switch2 != old_sw2)
            {
                selected_sw = 1;
            }
            if (switch3 != old_sw3)
            {
                selected_sw = 3;
            }
            if (btns & 0b0001) // if button 0 is pressed
            {
                btn0_action();
            }
            if (btns & 0b0010) // if button 1 is pressed
            {
                btn1_action();
            }
            if (btns & 0b0100) // if button 2 is pressed
            {
            }
            if (btns & 0b1000) // if button 3 is pressed
            {
                btn3_action();
            }
            if (state == RUNNING && (*status_ptr & 0x1)) {
                    *status_ptr = 0x1;
                    if (remaining_time > 0) {
                        remaining_time--;
                        time_studied++;
                    } else {
                        *control_ptr &= ~1u;
                        state = ENDED;
                    }
                }
        }
    }